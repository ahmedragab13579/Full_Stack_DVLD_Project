@model IEnumerable<(string Label, string Action, string Controller, object RouteValues, string Icon)>

<div class="relative group">
    <button class="h-9 w-9 rounded-xl bg-slate-800/60 flex items-center justify-center text-slate-400 hover:text-dvld-teal hover:bg-dvld-teal/10 transition-all border border-slate-700/50 shadow-sm">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
        </svg>
    </button>

    <div class="absolute right-0 mt-3 w-56 origin-top-right rounded-2xl bg-dvld-gray border border-slate-700 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 translate-y-3 transition-all duration-300 z-[60] backdrop-blur-xl">
        <div class="p-2 space-y-1">
            @foreach (var item in Model)
            {
                <a asp-action="@item.Action"
                   asp-controller="@item.Controller"
                   asp-all-route-data="@((IDictionary<string, string>)item.RouteValues)"
                   class="flex items-center gap-3.5 px-4 py-2.5 text-sm text-slate-300 hover:bg-dvld-teal/10 hover:text-dvld-teal rounded-xl transition-all duration-200 font-medium group/item">

                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <div class="text-slate-500 group-hover/item:text-dvld-teal transition-colors">
                            @Html.Raw(item.Icon)
                        </div>
                    }
                    else
                    {
                        <div class="h-1.5 w-1.5 rounded-full bg-slate-600 group-hover/item:bg-dvld-teal transition-all"></div>
                    }

                    <span class="flex-1">@item.Label</span>

                    <svg class="h-3.5 w-3.5 opacity-0 group-hover/item:opacity-100 -translate-x-2 group-hover/item:translate-x-0 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>
            }
        </div>
    </div>
</div>