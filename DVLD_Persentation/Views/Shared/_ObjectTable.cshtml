@model IEnumerable<object>

@{
    var items = Model?.ToList() ?? new List<object>();
}

@if (!items.Any())
{
    <div class="bg-dvld-gray/20 rounded-3xl border-2 border-dashed border-slate-700 py-20 text-center">
        <div class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-slate-800/50 mb-4 text-slate-600">
            <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-300">No Records Found</h3>
        <p class="text-sm text-slate-500 mt-1">Try adjusting your filters to find what you're looking for.</p>
    </div>
}
else
{
    var properties = items.First().GetType().GetProperties();

    <div class="bg-dvld-gray/20 rounded-3xl border border-white/5 overflow-hidden shadow-2xl backdrop-blur-sm">
        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-slate-800/40 border-b border-white/5">
                        <th class="px-6 py-5 w-4">
                            <input type="checkbox" class="h-4 w-4 rounded-md border-slate-600 bg-slate-900 text-dvld-teal focus:ring-dvld-teal transition-all" id="selectAll" />
                        </th>
                        @foreach (var property in properties)
                        {
                            <th class="px-6 py-5 text-left">
                                <button class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-slate-400 hover:text-dvld-teal transition-all group">
                                    @property.Name
                                    <svg class="h-3 w-3 opacity-0 group-hover:opacity-100 transition-all transform group-hover:translate-y-[-2px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg>
                                </button>
                            </th>
                        }
                        <th class="px-6 py-5 text-right text-[11px] font-bold uppercase tracking-widest text-slate-400">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.03]">
                    @for (int i = 0; i < items.Count; i++)
                    {
                        var item = items[i];
                        <tr class="hover:bg-white/[0.02] transition-colors group">
                            <td class="px-6 py-4">
                                <input type="checkbox" class="h-4 w-4 rounded-md border-slate-600 bg-slate-900 text-dvld-teal focus:ring-dvld-teal row-select" />
                            </td>
                            @foreach (var property in properties)
                            {
                                var value = property.GetValue(item);
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium text-slate-300">
                                        @if (value is bool b)
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight @(b ? "bg-emerald-500/10 text-emerald-500" : "bg-red-500/10 text-red-500")">
                                                <span class="h-1 w-1 rounded-full @(b ? "bg-emerald-500" : "bg-red-500")"></span>
                                                @(b ? "Yes" : "No")
                                            </span>
                                        }
                                        else if (property.Name.Contains("Status"))
                                        {
                                            var status = value?.ToString() ?? "Unknown";
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold bg-slate-800 text-slate-300 border border-white/5">
                                                @status
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="truncate max-w-[200px] block" title="@value">@(value ?? "-")</span>
                                        }
                                    </div>
                                </td>
                            }
                            <!-- Actions Column -->
                            <td class="px-6 py-4 text-right">
                                @{
                                    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
                                    var itemProps = item.GetType().GetProperties();
                                    var itemId = itemProps.FirstOrDefault(p => p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase) 
                                                                            || p.Name.Equals(controllerName + "Id", StringComparison.OrdinalIgnoreCase)
                                                                            || p.Name.EndsWith("ID", StringComparison.OrdinalIgnoreCase))
                                                          ?.GetValue(item);
                                }
                                <div class="flex justify-end gap-1 opacity-0 group-hover:opacity-100 transition-all translate-x-2 group-hover:translate-x-0">
                                    <a asp-controller="@controllerName" asp-action="Details" asp-route-id="@itemId" class="p-2 rounded-xl bg-slate-800 hover:bg-dvld-teal hover:text-dvld-dark transition-all text-slate-400" title="View Details">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                    <a asp-controller="@controllerName" asp-action="Edit" asp-route-id="@itemId" class="p-2 rounded-xl bg-slate-800 hover:bg-amber-500 hover:text-dvld-dark transition-all text-slate-400" title="Edit Record">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer / Pagination -->
        <div class="bg-slate-800/20 px-8 py-5 flex items-center justify-between border-t border-white/5">
            <div class="flex items-center gap-6">
                <p class="text-xs font-medium text-slate-500">Showing <span class="text-slate-200">@items.Count</span> records</p>
                <div class="h-4 w-px bg-slate-700"></div>
                <select class="bg-transparent border-none text-xs font-bold text-slate-400 focus:ring-0 cursor-pointer hover:text-dvld-teal">
                    <option class="bg-dvld-dark">10 Items</option>
                    <option class="bg-dvld-dark">25 Items</option>
                </select>
            </div>

            <div class="flex items-center gap-2">
                <button class="p-2 rounded-lg hover:bg-slate-800 text-slate-500 disabled:opacity-20 transition-all"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg></button>
                <div class="flex gap-1">
                    <span class="h-8 w-8 flex items-center justify-center bg-dvld-teal text-dvld-dark font-bold rounded-lg text-xs">1</span>
                    <span class="h-8 w-8 flex items-center justify-center hover:bg-slate-800 text-slate-400 rounded-lg text-xs cursor-pointer transition-all">2</span>
                </div>
                <button class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 transition-all"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
            </div>
        </div>
    </div>
}