@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<nav class="flex mb-8 overflow-x-auto whitespace-nowrap pb-2" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-2 md:space-x-4">
        <!-- Home Item -->
        <li class="inline-flex items-center">
            <a asp-controller="Home" asp-action="Index"
               class="inline-flex items-center text-sm font-medium text-slate-400 hover:text-dvld-teal transition-colors duration-200">
                <svg class="w-4 h-4 mr-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                Home
            </a>
        </li>

        @if (controller != "Home")
        {
            <li>
                <div class="flex items-center">
                    <!-- سهم بشكل أنحف وأرقى -->
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <a asp-controller="@controller" asp-action="Index"
                       class="ml-2 text-sm font-medium text-slate-400 hover:text-dvld-teal transition-colors duration-200">
                        @controller
                    </a>
                </div>
            </li>
        }

        @if (action != "Index")
        {
            <li aria-current="page">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <!-- النص الحالي بوزن أثقل ولون مشرق -->
                    <span class="ml-2 text-sm font-semibold text-dvld-teal tracking-wide">
                        @action
                    </span>
                </div>
            </li>
        }
    </ol>
</nav>