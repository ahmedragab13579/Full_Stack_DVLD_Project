@{
    ViewData["Title"] = "Replace License";
}

<form method="post" class="rounded border border-slate-700 bg-slate-900/60 p-5">
    @Html.AntiForgeryToken()
    <h2 class="mb-4 text-xl font-semibold text-[#EEEEEE]">Replace License</h2>
    <div asp-validation-summary="ModelOnly" class="mb-3 text-sm text-red-300"></div>
    <input type="hidden" name="id" value="@ViewBag.LicenseId" />
<div class="grid gap-3 md:grid-cols-2">
    <select name="reason" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm">
        <option>DamagedReplacement</option>
        <option>LostReplacement</option>
    </select>
    <input name="notes" placeholder="Replacement Notes" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" />
</div>
    <button class="mt-4 rounded bg-[#00ADB5] px-4 py-2 font-semibold text-[#222831]" type="submit">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

