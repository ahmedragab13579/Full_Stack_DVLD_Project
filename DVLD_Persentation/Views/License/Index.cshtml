@{
    ViewData["Title"] = "Licenses";
}

<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-dvld-teal/70">License Module</p>
        <h2 class="text-xl font-bold text-dvld-light">All Licenses</h2>
    </div>
    <div class="flex items-center gap-3">
        <!-- View Toggler -->
        <div id="viewControls" class="flex items-center gap-1 rounded-lg border border-slate-700 bg-slate-800/50 p-1">
            <button data-view="list" class="rounded p-1.5 text-dvld-teal bg-slate-700/50 transition-all" title="List View">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
            </button>
            <button data-view="grid" class="rounded p-1.5 text-slate-500 transition-all hover:text-dvld-teal" title="Grid View">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            </button>
        </div>
        <!-- Search -->
        <div class="relative">
            <input type="text" id="licenseSearch" placeholder="Search licenses..." aria-label="Search licenses"
                   class="bg-slate-800/50 border-slate-700 pl-9 pr-4 py-2 text-xs rounded-lg w-56" />
            <svg class="absolute left-3 top-2.5 h-3.5 w-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <!-- Status Filter -->
        <select aria-label="Filter by status" class="bg-slate-800/50 border-slate-700 text-xs py-2 pl-3 pr-8 rounded-lg hover:border-dvld-teal transition-colors focus:ring-dvld-teal">
            <option value="">All Statuses</option>
            <option value="active">Active</option>
            <option value="expired">Expired</option>
            <option value="suspended">Suspended</option>
        </select>
        <a asp-action="Issue" class="btn-primary py-2 px-5 text-xs">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Issue License
        </a>
    </div>
</div>

<partial name="_Filters" />

@{
    var rows = Model is IEnumerable<object> data
        ? data.Cast<object>().ToList()
        : new List<object>();
}

@if (!rows.Any())
{
    <div class="dvld-card">
        <div class="empty-state-container">
            <div class="empty-state-illustration">
                <svg class="w-full h-full text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">No Licenses Found</h3>
            <p class="text-xs text-slate-500 mb-8 max-w-xs mx-auto">No licenses have been issued yet. Issue a new license from an approved application.</p>
            <a asp-action="Issue" class="btn-primary py-2 px-8">Issue First License</a>
        </div>
    </div>
}
else
{
    <div id="viewContainer" class="view-container list-view">
        <div class="dvld-card overflow-hidden !p-0 border-slate-700/50 shadow-2xl">
            <div class="overflow-x-auto responsive-table-container">
                <table class="w-full text-left text-xs">
                    <thead>
                        <tr class="bg-dvld-dark/80 border-b border-slate-700 text-dvld-teal/80 font-bold uppercase tracking-widest">
                            <th class="px-6 py-4 w-4">
                                <input type="checkbox" id="selectAll" aria-label="Select all licenses" class="h-4 w-4 rounded border-slate-600 bg-transparent text-dvld-teal focus:ring-dvld-teal" />
                            </th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors"><div class="flex items-center gap-1">License # <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div></th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors"><div class="flex items-center gap-1">Driver <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div></th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors"><div class="flex items-center gap-1">Class <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div></th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors"><div class="flex items-center gap-1">Issue Date <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div></th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors"><div class="flex items-center gap-1">Expiry Date <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div></th>
                            <th class="px-6 py-4">Status</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @foreach (var item in rows)
                        {
                            var props = item.GetType().GetProperties().ToDictionary(p => p.Name, p => p.GetValue(item));
                            var licenseId = props.ContainsKey("LicenseID") ? props["LicenseID"] : props.ContainsKey("ID") ? props["ID"] : "-";
                            var driver = props.ContainsKey("DriverName") ? props["DriverName"] : props.ContainsKey("PersonName") ? props["PersonName"] : "-";
                            var licenseClass = props.ContainsKey("LicenseClass") ? props["LicenseClass"] : props.ContainsKey("Class") ? props["Class"] : "-";
                            var issueDate = props.ContainsKey("IssueDate") ? props["IssueDate"] : "-";
                            var expiryDate = props.ContainsKey("ExpiryDate") ? props["ExpiryDate"] : props.ContainsKey("ExpiredDate") ? props["ExpiredDate"] : "-";
                            var status = props.ContainsKey("Status") ? props["Status"]?.ToString() : "Active";
                            var statusClass = status?.ToLower() == "active" ? "status-success" : status?.ToLower() == "expired" ? "status-danger" : "status-pending";

                            <tr class="hover:bg-dvld-teal/5 transition-all group">
                                <td class="px-6 py-4">
                                    <input type="checkbox" class="row-select h-4 w-4 rounded border-slate-600 bg-transparent text-dvld-teal focus:ring-dvld-teal" />
                                </td>
                                <td class="px-6 py-4 font-mono font-bold text-dvld-teal">#@licenseId</td>
                                <td class="px-6 py-4 text-slate-300 font-medium">@driver</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center rounded-full bg-dvld-teal/10 px-2.5 py-1 text-[10px] font-bold text-dvld-teal border border-dvld-teal/20">@licenseClass</span>
                                </td>
                                <td class="px-6 py-4 text-slate-400">@issueDate</td>
                                <td class="px-6 py-4 text-slate-400">@expiryDate</td>
                                <td class="px-6 py-4">
                                    <span class="status-badge @statusClass">@status</span>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                    <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a asp-action="Details" asp-route-id="@licenseId" class="p-1.5 rounded-lg bg-slate-800 text-slate-400 hover:text-dvld-teal hover:bg-dvld-teal/10 transition-all" title="View Details">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        </a>
                                        <a asp-action="Renew" asp-route-id="@licenseId" class="p-1.5 rounded-lg bg-slate-800 text-slate-400 hover:text-emerald-400 hover:bg-emerald-400/10 transition-all" title="Renew License">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        </a>
                                        <button onclick="DVLD.showToast('Print feature coming soon', 'warning')" class="p-1.5 rounded-lg bg-slate-800 text-slate-400 hover:text-dvld-info hover:bg-dvld-info/10 transition-all" title="Print License">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                                        </button>
                                        <button onclick="DVLD.showToast('Download feature coming soon', 'warning')" class="p-1.5 rounded-lg bg-slate-800 text-slate-400 hover:text-dvld-secondary hover:bg-dvld-secondary/10 transition-all" title="Download License">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="bg-dvld-dark/50 border-t border-slate-700 px-6 py-4 flex items-center justify-between text-[10px] font-bold uppercase tracking-widest text-slate-500">
                <div class="flex items-center gap-4">
                    <span>Total: @rows.Count licenses</span>
                    <select aria-label="Page size" class="bg-transparent border-none text-[10px] uppercase font-bold focus:ring-0 cursor-pointer hover:text-dvld-teal">
                        <option>10 per page</option>
                        <option>25 per page</option>
                        <option>50 per page</option>
                    </select>
                </div>
                <div class="flex items-center gap-4">
                    <button class="hover:text-dvld-teal disabled:opacity-30 flex items-center gap-1" disabled>
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        Prev
                    </button>
                    <span class="px-2 py-1 bg-dvld-teal text-dvld-dark rounded">1</span>
                    <button class="hover:text-dvld-teal flex items-center gap-1">
                        Next
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        DVLD.initViewToggler('viewContainer', 'viewControls');

        const searchInput = document.getElementById('licenseSearch');
        if (searchInput) {
            searchInput.addEventListener('input', DVLD.debounce((e) => {
                const q = e.target.value.toLowerCase();
                document.querySelectorAll('tbody tr').forEach(row => {
                    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
                });
            }, 300));
        }

        const selectAll = document.getElementById('selectAll');
        if (selectAll) {
            selectAll.addEventListener('change', (e) => {
                document.querySelectorAll('.row-select').forEach(cb => cb.checked = e.target.checked);
            });
        }
    </script>
}
