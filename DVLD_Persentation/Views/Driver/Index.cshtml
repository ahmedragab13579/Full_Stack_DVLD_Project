@{
    ViewData["Title"] = "System Drivers";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h2 class="text-xl font-bold text-dvld-light">System Drivers</h2>
        <p class="text-xs text-slate-400 mt-1">Directory of all individuals with active or historical license records.</p>
    </div>
    
    <div class="flex items-center gap-3">
        <div class="relative">
            <input type="text" placeholder="Search drivers..." class="pl-10 text-xs py-2.5" />
            <svg class="absolute left-3 top-2.5 h-4 w-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
    </div>
</div>

@{
    var rows = Model is IEnumerable<object> data
        ? data.ToList()
        : new List<object>();
}

<partial name="_ObjectTable" model="rows" />
