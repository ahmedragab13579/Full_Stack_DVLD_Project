@model DVLD_Application.Dtos.AddDtos.CreateNewPersonDto
@{
    ViewData["Title"] = "Register Personal Profile";
    Layout = "_AuthLayout";
}

<div class="dvld-card shadow-2xl max-w-2xl mx-auto">
    <h2 class="text-xl font-bold text-white mb-6 text-center">Register Personal Profile</h2>

    <form asp-action="Register" method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-red-500 text-sm font-bold list-none"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label for="NationalNo" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">National Number</label>
                <input type="text" id="NationalNo" name="NationalNo" value="@Model?.NationalNo" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <div>
                <label for="DateOfBirth" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Date Of Birth</label>
                <input type="date" id="DateOfBirth" name="DateOfBirth" value="@(Model?.DateOfBirth.ToString("yyyy-MM-dd"))" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div>
                <label for="FirstName" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">First</label>
                <input type="text" id="FirstName" name="FirstName" value="@Model?.FirstName" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <div>
                <label for="SecondName" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Second</label>
                <input type="text" id="SecondName" name="SecondName" value="@Model?.SecondName" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <div>
                <label for="ThirdName" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Third</label>
                <input type="text" id="ThirdName" name="ThirdName" value="@Model?.ThirdName"
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <div>
                <label for="LastName" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Last</label>
                <input type="text" id="LastName" name="LastName" value="@Model?.LastName" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label for="Gender" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Gender</label>
                <select id="Gender" name="Gender" required class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all">
                    <option value="0" selected="@(Model?.Gender == DVLD_Domain.Enums.Gender.Male)">Male</option>
                    <option value="1" selected="@(Model?.Gender == DVLD_Domain.Enums.Gender.Female)">Female</option>
                </select>
            </div>
            <div>
                <label for="CountryID" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Country ID</label>
                <input type="number" id="CountryID" name="CountryID" value="@(Model?.CountryID > 0 ? Model.CountryID : 1)" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label for="Email" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Email Address</label>
                <input type="email" id="Email" name="Email" value="@Model?.Email" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <div>
                <label for="Phone" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Phone</label>
                <input type="tel" id="Phone" name="Phone" value="@Model?.Phone" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
        </div>

        <div>
            <label for="Address" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Address</label>
            <textarea id="Address" name="Address" rows="2" class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all">@Model?.Address</textarea>
        </div>

        <button type="submit" class="btn-primary w-full py-5 text-xl font-bold shadow-[0_4px_20px_rgba(0,173,181,0.3)] mt-4 transition-transform hover:scale-[1.01]">
            Register Profile
        </button>
    </form>

    <div class="mt-8 pt-6 border-t border-slate-700 text-center">
        <p class="text-sm text-slate-400">
            Already have an account?
            <a asp-action="Login" class="font-bold text-dvld-teal hover:underline ml-1">Sign in instead</a>
        </p>
    </div>
</div>