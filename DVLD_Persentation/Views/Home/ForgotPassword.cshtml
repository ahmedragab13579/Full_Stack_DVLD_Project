@{
    ViewData["Title"] = "Reset your password";
    Layout = "_AuthLayout";
}

<div class="dvld-card shadow-2xl max-w-md mx-auto">
    <!-- Step 1: Identification -->
    <div id="resetStep1">
        <div class="mb-8 text-center">
            <h3 class="text-xl font-bold text-white mb-2">Identify Your Account</h3>
            <p class="text-sm text-slate-400">Enter your email or username to receive a verification code.</p>
        </div>

        <form class="space-y-6">
            <div>
                <label class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Email / Username</label>
                <input type="text" name="usernameOrEmail" id="usernameOrEmail" placeholder="e.g. john@example.com" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <button type="button" onclick="showStep2()" class="btn-primary w-full py-5 text-xl font-bold shadow-[0_4px_15px_rgba(0,173,181,0.2)]">
                Send Code
            </button>
        </form>
    </div>

    <!-- Step 2: Verification Code (OTP) -->
    <div id="resetStep2" class="hidden">
        <div class="mb-8 text-center">
            <h3 class="text-xl font-bold text-white mb-2">Verification Code</h3>
            <p class="text-sm text-slate-400">We've sent a 6-digit code to your email.</p>
        </div>

        <form class="space-y-6">
            <div class="flex gap-2 justify-center">
                @for (int i = 0; i < 6; i++)
                {
                    <input type="text" name="otp_@i" maxlength="1"
                           class="w-12 h-14 text-center text-2xl font-bold bg-slate-900 border border-slate-700 rounded-lg text-dvld-teal focus:border-dvld-teal outline-none transition-all otp-input" />
                }
            </div>
            <button type="button" onclick="showStep3()" class="btn-primary w-full py-5 text-xl font-bold shadow-[0_4px_15px_rgba(0,173,181,0.2)] mt-4">
                Verify Code
            </button>
            <p class="text-center text-xs text-slate-500">
                Didn't receive code? <a href="#" class="text-dvld-teal hover:underline">Resend</a>
            </p>
        </form>
    </div>

    <!-- Step 3: New Password -->
    <div id="resetStep3" class="hidden">
        <div class="mb-8 text-center">
            <h3 class="text-xl font-bold text-white mb-2">New Password</h3>
            <p class="text-sm text-slate-400">Set a strong password for your account.</p>
        </div>

        <form asp-action="ResetPassword" method="post" class="space-y-5">
            <input type="hidden" name="usernameOrEmailHidden" id="usernameOrEmailHidden" />
            <div>
                <label class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">New Password</label>
                <input type="password" name="newPassword" placeholder="••••••••" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <div>
                <label class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Confirm Password</label>
                <input type="password" name="confirmPassword" placeholder="••••••••" required
                       class="w-full p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal outline-none transition-all" />
            </div>
            <button type="submit" class="btn-primary w-full py-5 text-xl font-bold shadow-[0_4px_15px_rgba(0,173,181,0.2)]">
                Update Password
            </button>
        </form>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-700 text-center">
        <a asp-action="Login" class="text-sm font-bold text-slate-500 hover:text-dvld-teal transition-colors flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Login
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function showStep2() {
            document.getElementById('resetStep1').classList.add('hidden');
            document.getElementById('resetStep2').classList.remove('hidden');
        }
        function showStep3() {
            document.getElementById('resetStep2').classList.add('hidden');
            document.getElementById('resetStep3').classList.remove('hidden');
        }

        // تحسين تجربة إدخال الكود (OTP) ليتحرك التحديد تلقائياً للحقل التالي
        const inputs = document.querySelectorAll('.otp-input');
        inputs.forEach((input, index) => {
            input.addEventListener('input', () => {
                if (input.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && input.value.length === 0 && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });
    </script>
}