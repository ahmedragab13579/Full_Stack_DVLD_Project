@{
    ViewData["Title"] = "Sign in to your account";
    Layout = "_AuthLayout";
}

<div class="dvld-card shadow-2xl max-w-md mx-auto">
    <h2 class="text-xl font-bold text-white mb-6 text-center">Login to DVLD</h2>

    <form asp-action="Login" method="post" class="space-y-6">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-bold list-none"></div>

        <div>
            <label for="userName" class="block text-sm font-bold uppercase tracking-widest text-slate-400 mb-2.5">Username</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <!-- Increased padding to p-5 and font to text-lg -->
                <input type="text" id="userName" name="userName" required
                       class="w-full pl-14 p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal focus:ring-1 focus:ring-dvld-teal outline-none transition-all"
                       placeholder="Enter your username" />
            </div>
        </div>

        <div>
            <div class="flex items-center justify-between mb-2.5">
                <label for="password" class="block text-sm font-bold uppercase tracking-widest text-slate-400">Password</label>
                <a asp-action="ForgotPassword" class="text-sm font-semibold text-dvld-teal hover:underline">Forgot?</a>
            </div>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <input type="password" id="password" name="password" required
                       class="w-full pl-14 p-5 bg-slate-900 border border-slate-700 rounded-xl text-white text-lg focus:border-dvld-teal focus:ring-1 focus:ring-dvld-teal outline-none transition-all"
                       placeholder="••••••••" />
            </div>
        </div>

        <div class="flex items-center">
            <input id="remember" name="remember" type="checkbox" class="h-5 w-5 rounded border-slate-700 bg-slate-900 text-dvld-teal focus:ring-dvld-teal cursor-pointer">
            <label for="remember" class="ml-3 block text-sm text-slate-400 cursor-pointer">Remember me for 30 days</label>
        </div>

        <button type="submit" class="btn-primary w-full py-5 text-xl font-bold shadow-[0_4px_20px_rgba(0,173,181,0.3)] transition-transform hover:scale-[1.02]">
            Sign In
        </button>
    </form>

    <div class="mt-8 pt-6 border-t border-slate-700 text-center">
        <p class="text-sm text-slate-400">
            Don't have an account?
            <a asp-action="Register" class="font-bold text-dvld-teal hover:underline ml-1">Create an account</a>
        </p>
    </div>
</div>