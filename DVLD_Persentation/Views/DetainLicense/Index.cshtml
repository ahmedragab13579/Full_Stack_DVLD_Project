@{
    ViewData["Title"] = "Detained Licenses";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h2 class="text-xl font-bold text-dvld-light">Detained Licenses</h2>
        <p class="text-xs text-slate-400 mt-1">Manage and track licenses held for enforcement reasons.</p>
    </div>
    
    <div class="flex items-center gap-3">
        <a asp-action="Release" class="px-6 py-2.5 rounded-lg border border-slate-700 bg-dvld-gray text-slate-300 text-xs font-bold uppercase tracking-widest hover:border-emerald-500 transition-all flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
            Release License
        </a>
        <a asp-action="Detain" class="btn-primary flex items-center gap-2 text-xs py-2.5 bg-red-500 hover:bg-red-600 text-white shadow-[0_0_15px_rgba(239,68,68,0.3)]">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            Detain License
        </a>
    </div>
</div>

@{
    var rows = Model is IEnumerable<object> data
        ? data.ToList()
        : new List<object>();
}

<partial name="_ObjectTable" model="rows" />
