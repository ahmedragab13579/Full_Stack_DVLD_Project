@{
    ViewData["Title"] = "Test Records";
}

<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-dvld-teal/70">Testing Module</p>
        <h2 class="text-xl font-bold text-dvld-light">Test Records</h2>
    </div>
    <div class="flex items-center gap-3">
        <!-- View Toggler -->
        <div id="viewControls" class="flex items-center gap-1 rounded-lg border border-slate-700 bg-slate-800/50 p-1">
            <button data-view="list" class="rounded p-1.5 text-dvld-teal bg-slate-700/50 transition-all" title="List View">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
            </button>
            <button data-view="grid" class="rounded p-1.5 text-slate-500 transition-all hover:text-dvld-teal" title="Grid View">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            </button>
        </div>
        <!-- Search -->
        <div class="relative">
            <input type="text" id="testSearch" placeholder="Search tests..." aria-label="Search test records"
                   class="bg-slate-800/50 border-slate-700 pl-9 pr-4 py-2 text-xs rounded-lg w-56" />
            <svg class="absolute left-3 top-2.5 h-3.5 w-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <a asp-action="Create" class="btn-primary py-2 px-5 text-xs">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Record Test
        </a>
    </div>
</div>

<partial name="_Filters" />

@{
    var rows = Model is IEnumerable<object> data
        ? data.Cast<object>().ToList()
        : new List<object>();
}

@if (!rows.Any())
{
    <div class="dvld-card">
        <div class="empty-state-container">
            <div class="empty-state-illustration">
                <svg class="w-full h-full text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">No Test Records Found</h3>
            <p class="text-xs text-slate-500 mb-8 max-w-xs mx-auto">No tests have been recorded yet. Start by recording a test result for an existing appointment.</p>
            <a asp-action="Create" class="btn-primary py-2 px-8">Record First Test</a>
        </div>
    </div>
}
else
{
    <!-- List View (default) -->
    <div id="viewContainer" class="view-container list-view">
        <div class="dvld-card overflow-hidden !p-0 border-slate-700/50 shadow-2xl">
            <div class="overflow-x-auto responsive-table-container">
                <table class="w-full text-left text-xs">
                    <thead>
                        <tr class="bg-dvld-dark/80 border-b border-slate-700 text-dvld-teal/80 font-bold uppercase tracking-widest">
                            <th class="px-6 py-4 w-4">
                                <input type="checkbox" id="selectAll" aria-label="Select all tests" class="h-4 w-4 rounded border-slate-600 bg-transparent text-dvld-teal focus:ring-dvld-teal" />
                            </th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors">
                                <div class="flex items-center gap-1">Test ID <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div>
                            </th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors">
                                <div class="flex items-center gap-1">Type <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div>
                            </th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors">
                                <div class="flex items-center gap-1">Applicant <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div>
                            </th>
                            <th class="px-6 py-4 cursor-pointer hover:text-white transition-colors">
                                <div class="flex items-center gap-1">Date <svg class="h-3 w-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg></div>
                            </th>
                            <th class="px-6 py-4">Result</th>
                            <th class="px-6 py-4">Appointment</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @foreach (var item in rows)
                        {
                            var props = item.GetType().GetProperties().ToDictionary(p => p.Name, p => p.GetValue(item));
                            var testId = props.ContainsKey("TestID") ? props["TestID"] : props.ContainsKey("ID") ? props["ID"] : "-";
                            var testType = props.ContainsKey("TestType") ? props["TestType"] : props.ContainsKey("Type") ? props["Type"] : "-";
                            var applicant = props.ContainsKey("ApplicantName") ? props["ApplicantName"] : props.ContainsKey("PersonName") ? props["PersonName"] : "-";
                            var testDate = props.ContainsKey("TestDate") ? props["TestDate"] : props.ContainsKey("Date") ? props["Date"] : "-";
                            var result = props.ContainsKey("Result") ? props["Result"]?.ToString() : "-";
                            var isPassed = result?.ToLower() == "pass" || result?.ToLower() == "passed" || result?.ToLower() == "true";
                            var appointmentId = props.ContainsKey("AppointmentID") ? props["AppointmentID"] : "-";

                            <tr class="hover:bg-dvld-teal/5 transition-all group">
                                <td class="px-6 py-4">
                                    <input type="checkbox" class="row-select h-4 w-4 rounded border-slate-600 bg-transparent text-dvld-teal focus:ring-dvld-teal" />
                                </td>
                                <td class="px-6 py-4 text-slate-300 font-mono font-bold">#@testId</td>
                                <td class="px-6 py-4 text-slate-300 font-medium">@testType</td>
                                <td class="px-6 py-4 text-slate-300">@applicant</td>
                                <td class="px-6 py-4 text-slate-400">@testDate</td>
                                <td class="px-6 py-4">
                                    @if (isPassed)
                                    {
                                        <span class="status-badge status-success">
                                            <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                            Pass
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-danger">
                                            <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                            Fail
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-slate-400">
                                    <a asp-controller="Appointment" asp-action="Details" asp-route-id="@appointmentId" class="text-dvld-teal hover:underline font-mono">#@appointmentId</a>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                    <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a asp-action="Details" asp-route-id="@testId" class="p-1.5 rounded-lg bg-slate-800 text-slate-400 hover:text-dvld-teal hover:bg-dvld-teal/10 transition-all" title="View Details">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        </a>
                                        @if (!isPassed)
                                        {
                                            <button onclick="DVLD.showToast('Retake option coming soon', 'warning')" class="p-1.5 rounded-lg bg-slate-800 text-slate-400 hover:text-amber-400 hover:bg-amber-400/10 transition-all" title="Schedule Retake">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="bg-dvld-dark/50 border-t border-slate-700 px-6 py-4 flex items-center justify-between text-[10px] font-bold uppercase tracking-widest text-slate-500">
                <div class="flex items-center gap-4">
                    <span>Total: @rows.Count records</span>
                    <select aria-label="Page size" class="bg-transparent border-none text-[10px] uppercase font-bold focus:ring-0 cursor-pointer hover:text-dvld-teal">
                        <option>10 per page</option>
                        <option>25 per page</option>
                        <option>50 per page</option>
                    </select>
                </div>
                <div class="flex items-center gap-4">
                    <button class="hover:text-dvld-teal disabled:opacity-30 flex items-center gap-1" disabled>
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        Prev
                    </button>
                    <span class="px-2 py-1 bg-dvld-teal text-dvld-dark rounded">1</span>
                    <button class="hover:text-dvld-teal flex items-center gap-1">
                        Next
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // View Toggler
        DVLD.initViewToggler('viewContainer', 'viewControls');

        // Search with debounce
        const searchInput = document.getElementById('testSearch');
        if (searchInput) {
            searchInput.addEventListener('input', DVLD.debounce((e) => {
                const q = e.target.value.toLowerCase();
                document.querySelectorAll('tbody tr').forEach(row => {
                    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
                });
            }, 300));
        }

        // Select All
        const selectAll = document.getElementById('selectAll');
        if (selectAll) {
            selectAll.addEventListener('change', (e) => {
                document.querySelectorAll('.row-select').forEach(cb => cb.checked = e.target.checked);
            });
        }
    </script>
}
