@{
    ViewData["Title"] = "Local License Applications";
}

<div class="w-full max-w-screen-xl mx-auto px-4 sm:px-6">
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-2xl font-bold text-white">Local License Applications</h2>
            <p class="text-sm text-slate-400 mt-2">Manage and track driver license applications.</p>
        </div>

        <div class="flex items-center gap-4">
            <a asp-action="Create" class="btn-primary flex items-center gap-2 text-sm font-bold py-3 px-6 shadow-lg">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                New Application
            </a>
        </div>
    </div>

    @{
        var rows = Model is IEnumerable<object> data
        ? data.ToList()
        : new List<object>();
    }

    <div class="overflow-x-auto w-full bg-slate-800/50 rounded-xl border border-slate-700">
        <partial name="_ObjectTable" model="rows" />
    </div>
</div>ص