@model DVLD_Application.Dtos.AddDtos.CreateNewAppointmentDto
@{
    ViewData["Title"] = "Schedule Test Appointment";
}

<div class="max-w-2xl mx-auto">
    <form asp-action="Create" method="post" class="bg-dvld-gray/30 rounded-[2rem] p-10 border border-white/5 shadow-2xl backdrop-blur-sm">
        @Html.AntiForgeryToken()

        <div class="mb-10 flex items-center justify-between border-b border-white/5 pb-6">
            <div>
                <h2 class="text-3xl font-extrabold text-white tracking-tight">Schedule Test</h2>
                <p class="text-sm text-slate-400 mt-2 font-medium">Book a new examination slot for the applicant.</p>
            </div>
            <div class="h-14 w-14 rounded-2xl bg-dvld-teal/10 flex items-center justify-center text-dvld-teal shadow-inner">
                <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="mb-8 rounded-2xl bg-red-500/10 border border-red-500/20 p-5 text-sm text-red-400"></div>

        <div class="grid gap-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="block text-[11px] font-black uppercase tracking-[0.15em] text-slate-500 ml-1">Application ID</label>
                    <input name="LocalDrivingLicenseApplicationID" value="@Model?.LocalDrivingLicenseApplicationID" required readonly
                           class="w-full bg-dvld-dark/50 border border-slate-700 rounded-xl px-4 py-3.5 text-sm text-slate-400 cursor-not-allowed outline-none" />
                </div>
                <div class="space-y-2">
                    <label class="block text-[11px] font-black uppercase tracking-[0.15em] text-slate-500 ml-1">Test Type</label>
                    <select name="TestTypeID" required class="w-full bg-dvld-dark border border-slate-700 rounded-xl px-4 py-3.5 text-sm text-white outline-none focus:border-dvld-teal appearance-none cursor-pointer">
                        <option value="1" selected="@(Model?.TestTypeID == 1)">Vision Test</option>
                        <option value="2" selected="@(Model?.TestTypeID == 2)">Written (Theory) Test</option>
                        <option value="3" selected="@(Model?.TestTypeID == 3)">Practical (Street) Test</option>
                    </select>
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-[11px] font-black uppercase tracking-[0.15em] text-slate-500 ml-1">Appointment Date & Time</label>
                <input name="AppointmentDate" type="datetime-local" required
                       class="w-full bg-dvld-dark border border-slate-700 rounded-xl px-4 py-3.5 text-sm text-white focus:border-dvld-teal outline-none transition-all" />
            </div>

            <div class="space-y-2">
                <label class="block text-[11px] font-black uppercase tracking-[0.15em] text-slate-500 ml-1">Test Fees</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-dvld-teal font-bold">$</span>
                    <input name="PaidFees" type="number" step="0.01" value="15.00" required
                           class="w-full bg-dvld-dark border border-slate-700 rounded-xl pl-8 pr-4 py-3.5 text-sm text-white focus:border-dvld-teal outline-none transition-all font-mono" />
                </div>
            </div>
        </div>

        <div class="mt-12 flex items-center justify-end gap-4 border-t border-white/5 pt-8">
            <button type="button" onclick="history.back()" class="text-sm font-bold uppercase tracking-widest text-slate-500 hover:text-white transition-colors px-6">Cancel</button>
            <button type="submit" class="bg-dvld-teal hover:bg-dvld-teal/90 text-dvld-dark font-black px-10 py-4 rounded-2xl text-sm uppercase tracking-widest transition-all shadow-xl shadow-dvld-teal/20">
                Confirm Booking
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}