@{
    ViewData["Title"] = "Edit License Class";
}

<form method="post" class="rounded border border-slate-700 bg-slate-900/60 p-5">
    @Html.AntiForgeryToken()
    <h2 class="mb-4 text-xl font-semibold text-[#EEEEEE]">Edit License Class</h2>
    <div asp-validation-summary="ModelOnly" class="mb-3 text-sm text-red-300"></div>
    <div class="grid gap-3 md:grid-cols-2">
    <input name="Id" type="number" min="1" placeholder="ID (for edit)" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" />
    <input name="ClassName" placeholder="Class Name" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" required />
    <input name="ClassDescription" placeholder="Class Description" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" />
    <input name="MinimumAllowedAge" type="number" min="0" max="120" placeholder="Minimum Age" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" required />
    <input name="DefaultValidityLength" type="number" min="0" max="255" placeholder="Validity Length" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" required />
    <input name="ClassFees" type="number" step="0.01" min="0" placeholder="Class Fees" class="rounded border border-slate-600 bg-slate-950 px-3 py-2 text-sm" required />
</div>
    <button class="mt-4 rounded bg-[#00ADB5] px-4 py-2 font-semibold text-[#222831]" type="submit">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

