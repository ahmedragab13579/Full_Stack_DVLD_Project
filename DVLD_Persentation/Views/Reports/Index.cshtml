@using DVLD_Application.Dtos.Reports
@model dynamic

@{
    ViewData["Title"] = "System Reports & Analytics";
    var reportType = ViewBag.Type as string;
    var fromDate = ViewBag.From as DateTime?;
    var toDate = ViewBag.To as DateTime?;
}

<div class="mb-10">
    <div class="flex items-center gap-3 mb-2">
        <span class="h-1.5 w-10 rounded-full bg-dvld-teal"></span>
        <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-500">Intelligence Unit</p>
    </div>
    <h1 class="text-4xl font-extrabold text-white tracking-tight">Reports & Analytics</h1>
    <p class="text-slate-400 mt-2 text-lg font-light">Filter and export system performance data and audit logs.</p>
</div>

<div class="grid gap-8 lg:grid-cols-4 items-start">
    <div class="lg:col-span-1 space-y-8">
        <div class="bg-dvld-gray/30 rounded-3xl p-8 border border-white/5 shadow-xl">
            <h3 class="text-xs font-bold uppercase tracking-widest text-dvld-teal mb-6 border-b border-white/5 pb-4">Filter Parameters</h3>
            <form method="get" asp-action="Index" class="space-y-6">
                <div class="space-y-2">
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-500 ml-1">Report Type</label>
                    <select name="type" class="w-full bg-dvld-dark border border-slate-700 rounded-xl px-4 py-3 text-sm text-white focus:border-dvld-teal outline-none transition-all appearance-none cursor-pointer">
                        <!option value="Applications Summary" @(reportType == "Applications Summary" ? "selected" : "")>Applications Summary</!option>
                        <!option value="Revenue Audit" @(reportType == "Revenue Audit" ? "selected" : "")>Revenue Audit</!option>
                        <!option value="Driver Demographics" @(reportType == "Driver Demographics" ? "selected" : "")>Driver Demographics</!option>
                        <!option value="Test Pass/Fail Rates" @(reportType == "Test Pass/Fail Rates" ? "selected" : "")>Test Pass/Fail Rates</!option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-500 ml-1">Date From</label>
                    <input type="date" name="from" value="@(fromDate?.ToString("yyyy-MM-dd"))" class="w-full bg-dvld-dark border border-slate-700 rounded-xl px-4 py-3 text-sm text-white focus:border-dvld-teal outline-none" />
                </div>
                <div class="space-y-2">
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-500 ml-1">Date To</label>
                    <input type="date" name="to" value="@(toDate?.ToString("yyyy-MM-dd"))" class="w-full bg-dvld-dark border border-slate-700 rounded-xl px-4 py-3 text-sm text-white focus:border-dvld-teal outline-none" />
                </div>
                <button type="submit" class="w-full bg-dvld-teal hover:bg-dvld-teal/90 text-dvld-dark font-black py-4 rounded-2xl text-xs uppercase tracking-widest transition-all shadow-lg shadow-dvld-teal/10 mt-4">Generate Report</button>
            </form>
        </div>

        <div class="bg-dvld-gray/30 rounded-3xl p-8 border border-white/5 shadow-xl">
            <h3 class="text-xs font-bold uppercase tracking-widest text-dvld-teal mb-6 border-b border-white/5 pb-4">Export Options</h3>
            <div class="grid grid-cols-2 gap-4">
                <button onclick="DVLD.showToast('Exporting to PDF...', 'info')" class="flex flex-col items-center justify-center p-5 rounded-2xl border border-slate-700 bg-dvld-dark/50 hover:border-dvld-teal transition-all group">
                    <svg class="h-8 w-8 text-slate-500 group-hover:text-dvld-teal mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span class="text-[10px] font-black uppercase tracking-tighter text-slate-500 group-hover:text-dvld-light">PDF</span>
                </button>
                <button onclick="DVLD.showToast('Exporting to Excel...', 'info')" class="flex flex-col items-center justify-center p-5 rounded-2xl border border-slate-700 bg-dvld-dark/50 hover:border-dvld-teal transition-all group">
                    <svg class="h-8 w-8 text-slate-500 group-hover:text-dvld-teal mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2a2 2 0 00-2-2H5a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2zm0-5V7a2 2 0 012-2h2a2 2 0 012 2v5m-6 0h6"></path></svg>
                    <span class="text-[10px] font-black uppercase tracking-tighter text-slate-500 group-hover:text-dvld-light">Excel</span>
                </button>
            </div>
        </div>
    </div>

    <div class="lg:col-span-3">
        @if (Model == null)
        {
            <div class="bg-dvld-gray/20 rounded-[2rem] border-2 border-dashed border-slate-700 py-32 text-center">
                <div class="inline-flex h-24 w-24 items-center justify-center rounded-full bg-slate-800/50 mb-8 text-slate-600">
                    <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2a2 2 0 00-2-2H5a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2zm0-5V7a2 2 0 012-2h2a2 2 0 012 2v5m-6 0h6"></path></svg>
                </div>
                <h3 class="text-2xl font-extrabold text-slate-500 uppercase tracking-widest">No Report Generated</h3>
                <p class="text-lg text-slate-600 mt-3 font-medium">Select parameters and click "Generate Report" to see results.</p>
            </div>
        }
        else
        {
            <div class="bg-dvld-gray/30 rounded-[2rem] border border-white/5 overflow-hidden shadow-2xl backdrop-blur-sm">
                <div class="bg-slate-800/40 p-10 border-b border-white/5 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                    <div>
                        <h3 class="text-2xl font-black text-white tracking-tight">@reportType</h3>
                        <p class="text-xs text-slate-500 uppercase font-bold tracking-[0.2em] mt-2">
                            @if (fromDate.HasValue || toDate.HasValue)
                            {
                                @(fromDate?.ToString("MMM dd, yyyy") ?? "Start") @(" — ") @(toDate?.ToString("MMM dd, yyyy") ?? "Present")
                            }
                            else
                            {
                                @("Historical Data Summary")
                            }
                        </p>
                    </div>
                    <div class="inline-flex items-center px-4 py-2 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-xs font-bold uppercase tracking-widest">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 mr-2 animate-pulse"></span>
                        Fresh: @DateTime.Now.ToString("HH:mm")
                    </div>
                </div>

                @if (Model is ReportSummaryDto summary)
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-white/5 border-b border-white/5 bg-dvld-dark/20">
                        <div class="p-10 text-center md:text-left">
                            <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 mb-2">Total Items</p>
                            <p class="text-5xl font-black text-white tracking-tighter">@summary.TotalCount.ToString("N0")</p>
                        </div>
                        <div class="p-10 text-center md:text-left">
                            <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 mb-2">Total Revenue</p>
                            <p class="text-5xl font-black text-dvld-teal tracking-tighter">$@summary.TotalRevenue.ToString("N2")</p>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="bg-dvld-dark/40 text-slate-500 uppercase font-black tracking-widest text-[10px] border-b border-white/5">
                                    <th class="px-8 py-6">Category / Date</th>
                                    <th class="px-8 py-6 text-right">Count</th>
                                    <th class="px-8 py-6 text-right">Revenue</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/[0.03]">
                                @foreach (var item in summary.Items)
                                {
                                    <tr class="hover:bg-white/[0.02] transition-colors group">
                                        <td class="px-8 py-5 text-dvld-light font-bold text-sm">@item.Category</td>
                                        <td class="px-8 py-5 text-slate-400 text-right font-mono text-sm">@item.Count.ToString("N0")</td>
                                        <td class="px-8 py-5 text-dvld-teal/80 text-right font-mono font-bold text-sm">$@item.Revenue.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>
</div>